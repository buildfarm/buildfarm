build --java_language_version=21
build --java_runtime_version=remotejdk_21

build --tool_java_language_version=21
build --tool_java_runtime_version=remotejdk_21


common --enable_platform_specific_config

build:fuse --define=fuse=true

# Workaround for https://github.com/bazelbuild/bazel/issues/3236
build:linux --sandbox_tmpfs_path=/tmp

build --nojava_header_compilation

test --nojava_header_compilation
test --enable_runfiles
test --test_tag_filters=-redis,-integration

# Stop recompiling protoc.
# https://fzakaria.com/2024/10/23/bazel-knowledge-mind-your-path.html
build --incompatible_strict_action_env

common --enable_bzlmod

# See also https://bazel.build/external/lockfile.
common --lockfile_mode=off
# It's off because we have mac/windows/linux developers who may not have access
# to all three to update the platform-specific bits of the lockfile.


build:linux --sandbox_add_mount_pair=/tmp
build:macos --sandbox_add_mount_pair=/var/tmp
build:windows --sandbox_add_mount_pair=C:\Temp

# Protobuf will be dropping support for MSVC + Bazel in 34.0.
# To continue using it until then, use the flag --define=protobuf_allow_msvc=true.
# For feedback or discussion, see github.com/protocolbuffers/protobuf/issues/20085.
build:windows --define=protobuf_allow_msvc=true

# Planned to be default in Bazel 9; see https://github.com/bazelbuild/bazel/issues/22080
common --incompatible_disable_native_repo_rules

# NullAway: plugin is always loaded via //bazel/rules:java.bzl wrapper,
# but disabled by default. Enable with: bazel build --config=nullaway //...
# In JSpecifyMode, only @NullMarked classes/packages are checked.
# AnnotatedPackages uses a placeholder; actual checking scope comes from @NullMarked.

build --javacopt=-XDcompilePolicy=simple
build --javacopt=-XepDisableWarningsInGeneratedCode
# Choose one of "AnnotatedPackages" OR "OnlyNullMarked", cannot choose both.
build --javacopt=-XepOpt:NullAway:AnnotatedPackages=build.buildfarm
#build --javacopt=-XepOpt:NullAway:OnlyNullMarked

build --javacopt=-XepOpt:NullAway:TreatGeneratedAsUnannotated=true
build --javacopt=-XepOpt:NullAway:CheckOptionalEmptiness=true
build --javacopt=-XepOpt:NullAway:SuggestSuppressions=true
# NullAway can run in "WARN" or "ERROR" mode (blocking) or "OFF" mode.
build --javacopt=-Xep:NullAway:WARN
build:nullaway --javacopt=-Xep:NullAway:ERROR
build:silence_nullaway --javacopt=-Xep:NullAway:OFF
